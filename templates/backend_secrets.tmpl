daemon:
  private_key: |
    ${daemon_private_key}
  jwt:
    secret: ${daemon_jwt_secret}
  metrics:
    authentication:
      enabled: ${daemon_metrics_authentication_enabled}
      username: ${daemon_metrics_authentication_username}
      password: ${daemon_metrics_authentication_password}

%{ if backend_s3_enabled ~}
storage:
  datastores:
    chorus:
      password: ${storage_datastores_chorus_password}
  file_stores:
    archive:
      minio_config:
        access_key_id: ${s3_access_key}
        secret_access_key: ${s3_secret_key}
%{ endif ~}

clients:
  k8s_client:
    is_watcher: ${k8s_client_is_watcher}
    api_server: ${k8s_client_api_server}
    image_pull_secrets:
%{ for s in k8s_client_image_pull_secrets ~}
    - registry: ${s.registry}
      username: ${s.username}
      password: ${s.password}
%{ endfor ~}

services:
  steward:
    init_user:
      password: ${steward_password}
  authentication_service:
    modes:
      keycloak:
        openid:
          client_secret: ${keycloak_openid_client_secret}
%{ if keycloak_dev_enabled ~}
      keycloakdev:
        openid:
          client_secret: ${keycloak_openid_client_secret}
%{ endif ~}
