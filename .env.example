# Mandatory variables
export TF_VAR_kubeconfig_path="/home/johndoe/.kube/config"
export TF_VAR_kubeconfig_context="kubeadmin@your-build-cluster"
export TF_VAR_cluster_name="chorus-build"

export TF_VAR_remote_cluster_kubeconfig_path="/home/johndoe/.kube/config"
export TF_VAR_remote_cluster_kubeconfig_context="kubeadmin@your-remote-cluster"
export TF_VAR_remote_cluster_name="chorus"
export TF_VAR_remote_cluster_server="your-remote-cluster-server-url"

export TF_VAR_helm_registry="your-favorite-registry"

# GitHub PAT for Argo Workflows
# Needs: Read access to actions, metadata, and repository hooks
#        Read and Write access to code, commit statuses, and pull requests
export TF_VAR_github_pat="github_pat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# GitHub App credentials for ArgoCD repository access and webhook eventsource
# Create a GitHub App, install it on your repositories, generate a private key
# The App ID and Installation ID can be found in the GitHub App settings page
export TF_VAR_github_app_id="123456"
export TF_VAR_github_app_installation_id="12345678"
export TF_VAR_github_app_private_key="-----BEGIN RSA PRIVATE KEY-----
XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
-----END RSA PRIVATE KEY-----"

export TF_VAR_i2b2_db_password="password"

